generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  accounts     Account[]
  transactions Transaction[]
  categories   Category[]
  plaidItems   PlaidItem[]

  @@map("users")
}

model Account {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  name          String
  type          AccountType
  balance       Decimal     @default(0) @db.Decimal(12, 2)
  institution   String?
  accountNumber String?     @map("account_number")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  plaidAccount PlaidAccount?

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  LOAN
  STOCK
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  accountId   String          @map("account_id")
  categoryId  String?         @map("category_id")
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String
  notes       String?
  date        DateTime
  receiptPath String?         @map("receipt_path")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Category {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String?
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@map("categories")
}

model PlaidItem {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  itemId          String    @unique @map("item_id")
  accessToken     String    @map("access_token")
  institutionName String?   @map("institution_name")
  status          String    @default("connected")
  lastSync        DateTime? @map("last_sync")
  syncError       String?   @map("sync_error")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plaidAccounts PlaidAccount[]

  @@map("plaid_items")
}

model PlaidAccount {
  id             String   @id @default(uuid())
  plaidItemId    String   @map("plaid_item_id")
  accountId      String   @unique @map("account_id")
  plaidAccountId String   @unique @map("plaid_account_id")
  syncCursor     String?  @map("sync_cursor")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  plaidItem PlaidItem @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("plaid_accounts")
}
